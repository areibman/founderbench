# FounderBench credentials — copy to <repo-root>/credentials.env and fill in.
# credentials.env is gitignored. NEVER commit real values.
#
# Every credential here is verified by machine/60-credentials.sh with a live CLI call.
# Use LIMITED accounts with SPENDING CAPS: one run must not be able to destroy the experiment.

# ── Machine ──────────────────────────────────────────────────────────────────
# Xcode version pin (installed via xcodes CLI in stage 20)
XCODE_VERSION="16.4"
# Password for the dedicated build keychain (stage 50) — generate: openssl rand -hex 16
FB_KEYCHAIN_PASSWORD=""

# ── Apple / App Store Connect ────────────────────────────────────────────────
# API key from App Store Connect → Users and Access → Integrations → App Store Connect API
ASC_KEY_ID=""
ASC_ISSUER_ID=""
ASC_PRIVATE_KEY_PATH="$HOME/.appstoreconnect/private/AuthKey_XXXXXXXX.p8"
APPLE_TEAM_ID=""
APP_BUNDLE_ID="com.example.yourapp"
# Distribution certificate for signing (imported into build keychain in stage 50)
APPLE_CERT_P12=""
APPLE_CERT_P12_PASSWORD=""
# Optional: directory of .mobileprovision files to install
PROVISIONING_PROFILES_DIR=""

# ── App repo ─────────────────────────────────────────────────────────────────
APP_REPO_URL="https://github.com/yourorg/yourapp.git"
APP_REPO_DIR="$HOME/work/app"
# Xcode scheme + workspace/project used by verify.sh and the ship-release skill
APP_XCODE_SCHEME=""
APP_XCODE_WORKSPACE=""   # e.g. App.xcworkspace (leave empty to use APP_XCODE_PROJECT)
APP_XCODE_PROJECT=""     # e.g. App.xcodeproj

# ── GitHub ───────────────────────────────────────────────────────────────────
# Fine-grained PAT scoped to ONLY the app repo (contents:rw, issues:rw, pull_requests:rw)
GITHUB_TOKEN=""

# ── Model provider (agent brain) ─────────────────────────────────────────────
# MiniMax / GLM — swappable. The interception proxy forwards to MODEL_UPSTREAM_URL.
# Z.ai CODING plan (verified working): OpenAI-compatible, base ".../api/coding/paas/v4",
# auth "Authorization: Bearer $MODEL_API_KEY". The standard API plan uses ".../api/paas/v4".
MODEL_PROVIDER="openai-compatible"       # opencode provider npm: @ai-sdk/openai-compatible
MODEL_ID="glm-5.2"
MODEL_API_KEY=""                          # your ZAI_API_KEY (coding plan)
MODEL_UPSTREAM_URL="https://api.z.ai/api/coding/paas/v4"   # coding plan base URL

# ── Meta Ads (Pipeboard remote MCP) ──────────────────────────────────────────
# Auth is OAuth via `opencode mcp auth meta_ads` (stage 65) — no token needed here.
# Ad account id only used for verification reads:
META_AD_ACCOUNT_ID="act_XXXXXXXXX"

# ── RevenueCat ───────────────────────────────────────────────────────────────
# Secret API key (v2), project-scoped
REVENUECAT_API_KEY=""
REVENUECAT_PROJECT_ID=""

# ── meow.com banking ─────────────────────────────────────────────────────────
# Auth is via the meow remote MCP OAuth (stage 65). If meow issues an API token for
# scripted access, put it here for orchestrator-side balance polling:
MEOW_API_TOKEN=""

# ── Fastmail (agent's dedicated mailbox) ─────────────────────────────────────
# JMAP API token: Fastmail Settings → Privacy & Security → Manage API tokens
FASTMAIL_JMAP_TOKEN=""
FASTMAIL_ACCOUNT_EMAIL="founder@yourappdomain.com"

# ── Exa (web search MCP) ─────────────────────────────────────────────────────
EXA_API_KEY=""

# ── Budgets (enforced by orchestrator; also set caps at the account level!) ──
FB_MAX_BUSINESS_SPEND_USD="200"
FB_MAX_TOKEN_SPEND_USD="100"
