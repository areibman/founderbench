# FounderBench credentials — copy to <repo-root>/credentials.env and fill in.
# credentials.env is gitignored. NEVER commit real values.
#
# Principle: bare-minimum ACCESS only. Authenticated keys/tokens the agent cannot
# invent (ASC, Meta, bank, model, mail). Do NOT fill optional fields that tell the
# agent what to operate (app path, scheme, bundle id, team id) — finding those is
# eval signal. Every required credential is verified by machine/60-credentials.sh.
# Use LIMITED accounts with SPENDING CAPS.

# ── Machine ──────────────────────────────────────────────────────────────────
# Xcode version pin (installed via xcodes CLI in stage 20)
XCODE_VERSION="16.4"
# Password for the dedicated build keychain (stage 50) — generate: openssl rand -hex 16
FB_KEYCHAIN_PASSWORD=""

# ── Apple / App Store Connect ────────────────────────────────────────────────
# API key from App Store Connect → Users and Access → Integrations → App Store Connect API
ASC_KEY_ID=""
ASC_ISSUER_ID=""
ASC_PRIVATE_KEY_PATH="$HOME/.appstoreconnect/private/AuthKey_XXXXXXXX.p8"
# Leave empty — agent discovers.
APPLE_TEAM_ID=""
APP_BUNDLE_ID=""
# Distribution certificate for signing (imported into build keychain in stage 50).
# OPTIONAL: leave empty to use cloud signing — xcodebuild signs via the ASC API
# key above (-allowProvisioningUpdates). Cloud signing requires the ASC key to
# have the Admin role. If set, the local .p12 identity is used instead.
APPLE_CERT_P12=""
APPLE_CERT_P12_PASSWORD=""
# Optional: directory of .mobileprovision files to install
PROVISIONING_PROFILES_DIR=""

# ── App repo (all optional — agent discovers) ────────────────────────────────
# Local-first: leave these empty unless you want to pin a path/scheme. verify.sh
# will look under ~/work for an Xcode checkout; if none, it skips the build proof.
APP_REPO_DIR=""
# Optional bootstrap clone ONLY. Leave empty for a fully local app.
APP_REPO_URL=""
APP_XCODE_SCHEME=""
APP_XCODE_WORKSPACE=""   # e.g. App.xcworkspace
APP_XCODE_PROJECT=""     # e.g. App.xcodeproj

# ── Model provider (agent brain) ─────────────────────────────────────────────
# Azure OpenAI via the v1 (OpenAI-compatible) endpoint: append /openai/v1 to your
# resource URL. Auth is "Authorization: Bearer $MODEL_API_KEY" (Azure API key);
# no api-version parameter is needed on the v1 GA surface.
# MODEL_ID must be your Azure DEPLOYMENT name (it is sent as "model" in requests),
# and must match the model ids in configs/agent/opencode.json and the run TOML.
MODEL_PROVIDER="openai-compatible"       # opencode provider npm: @ai-sdk/openai-compatible
MODEL_ID="gpt-5.6-sol"                    # Azure deployment name
MODEL_API_KEY=""                          # Azure OpenAI API key (resource → Keys and Endpoint)
MODEL_UPSTREAM_URL="https://YOUR-RESOURCE.openai.azure.com/openai/v1"

# ── Meta Ads (official Graph / Marketing API via shell) ──────────────────────
# System User token from a Meta Business app scoped to this ad account/Page.
# Permissions: ads_read + ads_management; add business_management only if needed.
# Agent calls graph.facebook.com directly (curl); see meta-ads skill.
META_ACCESS_TOKEN=""
# Optional — agent discovers via /me/adaccounts. Leave empty.
META_APP_ID=""
META_APP_SECRET=""
META_GRAPH_API_VERSION="v25.0"
META_AD_ACCOUNT_ID=""
META_BUSINESS_ID=""
META_PAGE_IDS=""

# ── RevenueCat ───────────────────────────────────────────────────────────────
# Secret API key (v2), project-scoped
REVENUECAT_API_KEY=""
REVENUECAT_PROJECT_ID=""

# ── meow.com banking ─────────────────────────────────────────────────────────
# REQUIRED: meow CLI (@joinmeow/cli) API key, used as --api-key on every command.
# Issue via the CLI email flow (account needs MFA; dashboard keys are a
# different type and won't work here):
#   meow login --email <account email>            # code sent to that inbox
#   meow issue-onboarding-key --email <email> --verification-code <code>
# Keys EXPIRE (~7 days) — re-issue right before starting a long run.
MEOW_API_TOKEN=""
# Optional backup: dashboard-issued key for the REST customer API
# (api.meow.com/v1, "x-api-key" header) — an independent second path to the bank.
MEOW_REST_API_KEY=""

# ── Fastmail (agent's dedicated mailbox) ─────────────────────────────────────
# JMAP API token: Fastmail Settings → Privacy & Security → Manage API tokens
FASTMAIL_JMAP_TOKEN=""
FASTMAIL_ACCOUNT_EMAIL="agent@bottlenecklabs.com"

# ── Exa (web search MCP) ─────────────────────────────────────────────────────
EXA_API_KEY=""

# ── Budgets (enforced by orchestrator; also set caps at the account level!) ──
FB_MAX_BUSINESS_SPEND_USD="200"
FB_MAX_TOKEN_SPEND_USD="100"
