{
  "$schema": "https://opencode.ai/config.json",

  "model": "founderbench/gpt-5.2",

  "provider": {
    "founderbench": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "FounderBench traced provider",
      "options": {
        "baseURL": "http://127.0.0.1:41500/v1",
        "apiKey": "{env:MODEL_API_KEY}"
      },
      "models": {
        "gpt-5.2": { "name": "Azure OpenAI deployment (via interception proxy)" }
      }
    }
  },

  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "skill": { "*": "allow" }
  },

  "mcp": {
    "meta_ads": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "exec \"$(git rev-parse --show-toplevel)/tools/meta-ads-mcp.sh\""
      ],
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "headers": { "x-api-key": "{env:EXA_API_KEY}" },
      "oauth": false,
      "enabled": true
    },
    "fastmail": {
      "type": "remote",
      "url": "https://api.fastmail.com/mcp",
      "enabled": true
    },
    "xcmcp": {
      "type": "local",
      "command": ["xcmcp", "--wait-for-xcode=0s"],
      "enabled": true,
      "timeout": 20000
    },
    "axmcp": {
      "type": "local",
      "command": ["axmcp"],
      "enabled": true
    }
  },

  "tools": {
    "axmcp_*": false
  },

  "agent": {
    "build": {
      "tools": {
        "meta_ads_*": true,
        "fastmail_*": true
      }
    },
    "task": {
      "tools": {
        "meta_ads_*": false,
        "fastmail_*": false
      }
    }
  }
}
